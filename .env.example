# ========================================
# Mirai Backend 環境変数サンプル
# 本番値は Railway 環境変数 / ローカル .env に設定（コミット禁止）
# ========================================

# --- 必須 ---

# Anthropic Claude API キー
# 取得: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LiveAvatar API キー（トークン発行・アバター状態チェックに必須）
LIVEAVATAR_API_KEY=your-liveavatar-key-here

# --- オプション ---

# サーバ待受ポート（デフォルト 3001、Paperclip 同居環境では 3011 推奨）
PORT=3001

# 本番アバターID（LiveAvatar 承認済みの UUID。未指定時はコード定数を使用）
# 例: 1fdb012b-def9-435c-a297-fb8717556d02
DEFAULT_AVATAR_ID=

# サンドボックスアバターID（常時利用可、フォールバック先）
# 例: dd73ea75-1218-4ef3-92ce-606d5f7fbc0a （Wayne）
SANDBOX_AVATAR_ID=

# 本番アバターが avatar_not_found を返した時、サンドボックスへ自動フォールバックするか
# true（デフォルト）: 承認待ち期間でも UX を止めない
# false: フォールバックせずユーザーにエラー表示
USE_SANDBOX_FALLBACK=true

# --- レガシー（廃止予定） ---

# HeyGen Streaming Avatar 旧API用（/api/heygen-token でのみ参照、新機能では不使用）
HEYGEN_API_KEY=
